<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f1a"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:id="@+id/homeInnerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="120dp">

        <!-- Top bar: greeting + BAC card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/good_evening"
                    android:textColor="#ffffff"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvSessionTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_active_session"
                    android:textColor="#444466"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- BAC card -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="10dp"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BAC"
                    android:textColor="#444466"
                    android:textSize="9sp"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvBac"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:textColor="#5ab4ff"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- Stat cards row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="12dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/water_needed"
                    android:textColor="#444466"
                    android:textSize="10sp"
                    android:layout_marginBottom="3dp" />

                <TextView
                    android:id="@+id/tvWaterNeeded"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 ml"
                    android:textColor="#5ab4ff"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="12dp"
                android:layout_marginStart="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/water_consumed"
                    android:textColor="#444466"
                    android:textSize="10sp"
                    android:layout_marginBottom="3dp" />

                <TextView
                    android:id="@+id/tvWaterConsumed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 ml"
                    android:textColor="#34d399"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- Anime character card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:layout_marginBottom="10dp">

            <ImageView
                android:id="@+id/ivAnimeCharacter"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:src="@drawable/anime_sober"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvCharacterState"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/state_sober"
                        android:textColor="#ffffff"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="3dp" />

                    <TextView
                        android:id="@+id/tvCharacterMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/msg_sober"
                        android:textColor="#555577"
                        android:textSize="11sp"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvStateLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/level_1"
                    android:textColor="#34d399"
                    android:textSize="9sp"
                    android:background="@drawable/card_background"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Drunkenness bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="7dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/drunkenness"
                    android:textColor="#666688"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvDrunkenessPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#34d399"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressDrunkeness"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_bar_drawable" />

        </LinearLayout>

        <!-- Hydration bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="12dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="7dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/hydration"
                    android:textColor="#666688"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvHydrationPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#5ab4ff"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressHydration"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_bar_drawable" />

        </LinearLayout>

        <!-- Add water buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/btn250ml"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="+ 250 ml"
                android:textColor="#5ab4ff"
                android:background="@drawable/water_button_background"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <Button
                android:id="@+id/btn500ml"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="+ 500 ml"
                android:textColor="#5ab4ff"
                android:background="@drawable/water_button_background"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>

        <!-- Current session label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/current_session"
            android:textColor="#333355"
            android:textSize="10sp"
            android:letterSpacing="0.08"
            android:layout_marginBottom="7dp" />

        <!-- Drink log -->
        <LinearLayout
            android:id="@+id/llDrinkLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:layout_marginBottom="10dp" />

        <!-- Save session button -->
        <Button
            android:id="@+id/btnSaveSession"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/save_session"
            android:textColor="#34d399"
            android:background="@drawable/save_button_background"
            android:textSize="13sp"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>