<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSessionDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#ccccee"
            android:textSize="13sp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/tvSessionDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#444466"
            android:textSize="10sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvSessionHydration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginEnd="8dp" />

    <TextView
        android:id="@+id/btnSeeMore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/see_more"
        android:textColor="#5ab4ff"
        android:textSize="10sp"
        android:background="@drawable/see_more_background"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp" />

</LinearLayout>