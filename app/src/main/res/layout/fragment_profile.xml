<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f1a"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:id="@+id/profileInnerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingTop="22dp"
        android:paddingBottom="24dp">

        <!-- Page title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/your_profile"
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/profile_subtitle"
            android:textColor="#444466"
            android:textSize="11sp"
            android:layout_marginBottom="18dp" />

        <!-- Stat chips -->
        <LinearLayout
            android:id="@+id/layoutStatChips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/chipWeight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="8dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:id="@+id/tvChipWeight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#5ab4ff"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chip_weight"
                    android:textColor="#666688"
                    android:textSize="10sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/chipHeight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="8dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:id="@+id/tvChipHeight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#5ab4ff"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chip_height"
                    android:textColor="#666688"
                    android:textSize="10sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/chipAge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="8dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:id="@+id/tvChipAge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#5ab4ff"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chip_age"
                    android:textColor="#666688"
                    android:textSize="10sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/chipGender"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="8dp"
                android:layout_marginStart="4dp">

                <TextView
                    android:id="@+id/tvChipGender"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#5ab4ff"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chip_gender"
                    android:textColor="#666688"
                    android:textSize="10sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Profile fields card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="14dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_name"
                android:textColor="#444466"
                android:textSize="10sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/input_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#ffffff"
                android:textColorHint="#333355"
                android:hint="@string/hint_name"
                android:inputType="textCapWords"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_weight"
                android:textColor="#444466"
                android:textSize="10sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etWeight"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/input_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#ffffff"
                android:textColorHint="#333355"
                android:hint="@string/hint_weight"
                android:inputType="numberDecimal"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_height"
                android:textColor="#444466"
                android:textSize="10sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etHeight"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/input_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#ffffff"
                android:textColorHint="#333355"
                android:hint="@string/hint_height"
                android:inputType="number"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_age"
                android:textColor="#444466"
                android:textSize="10sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etAge"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/input_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#ffffff"
                android:textColorHint="#333355"
                android:hint="@string/hint_age"
                android:inputType="number" />

        </LinearLayout>

        <!-- Gender card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="14dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_gender"
                android:textColor="#444466"
                android:textSize="10sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnMale"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="@string/male"
                    android:textColor="#444466"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:background="@drawable/radio_unselected_background"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/btnFemale"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="@string/female"
                    android:textColor="#444466"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:background="@drawable/radio_unselected_background"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Language card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="14dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_language"
                android:textColor="#444466"
                android:textSize="10sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnLangEn"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="English"
                    android:textColor="#5ab4ff"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:background="@drawable/radio_selected_background"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/btnLangBg"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Български"
                    android:textColor="#444466"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:background="@drawable/radio_unselected_background"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Save button -->
        <Button
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="@string/save_profile"
            android:textColor="#0f0f1a"
            android:background="@drawable/save_profile_button_background"
            android:textSize="14sp"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginBottom="20dp" />

        <!-- Past sessions label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/past_sessions"
            android:textColor="#333355"
            android:textSize="10sp"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp" />

        <!-- Sessions list -->
        <LinearLayout
            android:id="@+id/llSessionsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>